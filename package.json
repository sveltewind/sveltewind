{
	"name": "sveltewind",
	"version": "4.1.3",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"package": "svelte-package",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"prepublishOnly": "npm run package",
		"npm-publish": "git push --follow-tags origin main && npm publish",
		"release": "commit-and-tag-version && npm run npm-publish"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"svelte": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./attachments": {
			"svelte": "./dist/attachments/index.js",
			"types": "./dist/attachments/index.d.ts"
		},
		"./components": {
			"svelte": "./dist/components/index.js",
			"types": "./dist/components/index.d.ts"
		},
		"./icons": {
			"svelte": "./dist/icons/index.js",
			"types": "./dist/icons/index.d.ts"
		},
		"./theme": {
			"svelte": "./dist/theme/index.js",
			"types": "./dist/theme/index.d.ts"
		},
		"./themes": {
			"svelte": "./dist/themes/index.js",
			"types": "./dist/themes/index.d.ts"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.36.0",
		"@lucide/svelte": "^0.548.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-vercel": "^5.10.2",
		"@sveltejs/kit": "^2.43.2",
		"@sveltejs/package": "^2.5.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.0",
		"@tailwindcss/vite": "^4.1.13",
		"@types/node": "^22",
		"@vitest/browser": "^3.2.4",
		"commit-and-tag-version": "^12.6.0",
		"eslint": "^9.36.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.4",
		"globals": "^16.4.0",
		"mdsvex": "^0.12.6",
		"playwright": "^1.55.1",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"publint": "^0.3.13",
		"rehype-add-classes": "^1.0.0",
		"svelte": "^5.39.5",
		"svelte-check": "^4.3.2",
		"tailwind-scrollbar": "^4.0.2",
		"tailwindcss": "^4.1.13",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.44.1",
		"vite": "^7.1.7",
		"vitest": "^3.2.4",
		"vitest-browser-svelte": "^1.1.0"
	},
	"keywords": [
		"svelte"
	],
	"dependencies": {
		"hast-util-to-html": "^9.0.5",
		"motion": "^12.23.24",
		"shiki": "^4.0.2",
		"tailwind-merge": "^3.3.1"
	},
	"publishConfig": {
		"access": "public"
	}
}
